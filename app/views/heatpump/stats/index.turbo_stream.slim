= turbo_stream.update frame_id('timeframe') do
  = render Timeframe::Component.new(timeframe:)

- if timeframe.now? && Sensor::Config.exists?(:heatpump_status)
  = turbo_stream.update frame_id('status') do
    = render Status::Component.new time: data.time,
                                   status: data.heatpump_status

= turbo_stream.update frame_id('stats'), method: :morph do
  ruby:
    focus_ring_classes = 'focus:outline-none focus:ring-2 focus:ring-gray-700 dark:focus:ring-gray-400 focus:ring-offset-0'
    card_base_classes = "click-animation block min-w-0 rounded-xl #{focus_ring_classes}"
    kpi_link_classes = "#{card_base_classes} min-w-0 basis-auto grow [&>div]:w-full"

  .h-full.w-full.flex.flex-col.gap-3.lg:gap-4.xl:gap-5 id= "stats-#{timeframe.id}"
    - if data.heatpump_power
      .flex.w-full.items-stretch.gap-1.md:gap-2.text-slate-700.dark:text-slate-400
        = link_to url_for(controller: 'home', sensor_name: 'heatpump_power', timeframe:),
                  class: "#{card_base_classes} grow min-w-0 #{"bg-slate-200 dark:bg-slate-800 px-3 py-2.5 md:px-4 #{'rounded-r-none' if data.heatpump_costs}" unless timeframe.now?}",
                  data: { \
                    turbo_prefetch: 'false',
                    'stats-with-chart--component-target': 'current',
                    'sensor-name': 'heatpump_power',
                    value: data.heatpump_power,
                    time: data.time.to_i,
                    action: 'stats-with-chart--component#loadChart',
                    stats_with_chart__component_sensor_name_param: 'heatpump_power',
                    stats_with_chart__component_chart_url_param: heatpump_charts_path(sensor_name: 'heatpump_power', timeframe:),
                  } do
          - if !timeframe.now? && data.heatpump_power_grid_ratio
            - power_pv_ratio = 100 - data.heatpump_power_grid_ratio
            .text-center.text-sm
              div
                = t('splitter.pv_percent', percent: power_pv_ratio.round)
              .w-full.flex.gap-px.rounded.overflow-hidden.mt-1
                - if power_pv_ratio.positive?
                  .h-3.bg-sensor-pv[
                    style= "width: #{power_pv_ratio}%;"
                  ]
                - if data.heatpump_power_grid_ratio.positive?
                  .h-3.bg-sensor-grid[
                    style= "width: #{data.heatpump_power_grid_ratio}%;"
                  ]
          - if timeframe.now?
            = render RectBadge::Component.new(title: t('sensors.heatpump_power_short')) do
              = render SensorValue::Component.new(data, :heatpump_power, context: :rate)
          - else
            .text-center class=("#{'mt-3' if data.heatpump_power_grid_ratio}")
              = render SensorValue::Component.new(data, :heatpump_power, context: :total, class: 'text-2xl md:text-3xl')

        - if !timeframe.now? && data.heatpump_costs
          = link_to url_for(controller: 'home', sensor_name: 'heatpump_costs', timeframe:),
                    class: "click-animation block shrink-0 h-full rounded-xl rounded-l-none #{focus_ring_classes}",
                    data: { \
                      controller: 'tooltip',
                      tooltip_placement_value: 'bottom',
                      tooltip_force_tap_to_close_value: false,
                      tooltip_touch_value: 'long',
                      turbo_prefetch: 'false',
                      'stats-with-chart--component-target': 'current',
                      'sensor-name': 'heatpump_costs',
                      value: data.heatpump_costs,
                      time: data.time.to_i,
                      action: 'stats-with-chart--component#loadChart',
                      stats_with_chart__component_sensor_name_param: 'heatpump_costs',
                      stats_with_chart__component_chart_url_param: heatpump_charts_path(sensor_name: 'heatpump_costs', timeframe:),
                    } do
            = render RectBadge::Component.new(title: t('sensors.heatpump_costs_short'), css_class: 'h-full rounded-l-none justify-center px-3 md:px-4') do
              = render SensorValue::Component.new(data.heatpump_costs, :total_costs, sign: :negative)
            #tooltip-content-heatpump_costs.hidden data-tooltip-target= 'html'
              = render SplittedCosts::Component.new( \
                  costs: data.heatpump_costs,
                  power_grid_ratio: data.heatpump_power_grid_ratio,
                  grid_costs: data.heatpump_costs_grid,
                  pv_costs: data.heatpump_costs_pv,
                  show_power_breakdown: false,
                )

    ruby:
      donut_heating_url = heatpump_home_path(sensor_name: 'heatpump_heating_power', timeframe:)
      donut_chart_url = heatpump_charts_path(sensor_name: 'heatpump_heating_power', timeframe:)

    - if data.heatpump_heating_power.nil? || data.heatpump_heating_power.zero?
      = render DonutChart::Component.new do |chart|
        - chart.with_center do
          p class="text-slate-500 dark:text-slate-400 leading-tight text-[clamp(0.75rem,8cqmin,1.25rem)]"
            = t('data.heatpump_no_heating')

    - elsif data.heatpump_power && data.heatpump_heating_power >= data.heatpump_power
      ruby:
        donut_segments = [
          {
            percent: data.heatpump_power_env_percent,
            color_var: '--color-sensor-heatpump-env',
            label: Sensor::Registry[:heatpump_power_env].display_name,
            sensor_name: 'heatpump_power_env',
          },
        ]
        if timeframe.now?
          donut_segments << {
            percent: data.heatpump_power_percent_heating,
            color_var: '--color-sensor-heatpump',
            label: t('splitter.total'),
            sensor_name: 'heatpump_power',
          }
        else
          donut_segments.push(
            {
              percent: data.heatpump_power_pv_percent,
              color_var: '--color-sensor-pv',
              label: t('splitter.pv'),
              sensor_name: 'heatpump_power_pv',
            },
            {
              percent: data.heatpump_power_grid_percent,
              color_var: '--color-sensor-grid',
              label: t('splitter.grid'),
              sensor_name: 'heatpump_power_grid',
            },
          )
        end

      = render DonutChart::Component.new(segments: donut_segments, url: donut_heating_url, chart_url: donut_chart_url, tooltip_placement: 'bottom') do |chart|
        - chart.with_center do
          = render Heatpump::CopBadge::Component.new(data:, timeframe:)

    - elsif data.heatpump_heating_power&.positive?
      ruby:
        donut_segments = []
        if timeframe.now?
          donut_segments << {
            percent: 100,
            color_var: '--color-sensor-heatpump',
            label: t('splitter.total'),
            sensor_name: 'heatpump_power',
          }
        else
          pv_ratio = data.heatpump_power_grid_ratio ? (100 - data.heatpump_power_grid_ratio) : 0
          grid_ratio = data.heatpump_power_grid_ratio || 100
          donut_segments.push(
            {
              percent: pv_ratio,
              color_var: '--color-sensor-pv',
              label: t('splitter.pv'),
              sensor_name: 'heatpump_power_pv',
            },
            {
              percent: grid_ratio,
              color_var: '--color-sensor-grid',
              label: t('splitter.grid'),
              sensor_name: 'heatpump_power_grid',
            },
          )
        end

      = render DonutChart::Component.new(segments: donut_segments, url: donut_heating_url, chart_url: donut_chart_url, tooltip_placement: 'bottom') do |chart|
        - chart.with_center do
          .flex.flex-col.items-center
            p class="hidden md:block text-slate-500 dark:text-slate-400 text-center leading-tight text-[clamp(0.6rem,6cqmin,0.875rem)]"
              = t('data.heatpump_cop_below_one')
            = render Heatpump::CopBadge::Component.new(data:, timeframe:, css_class: 'mt-1')

    - if data.heatpump_tank_temp || data.outdoor_temp || data.heatpump_heating_power&.positive?
      .flex.w-full.flex-nowrap.gap-2.lg:gap-4.xl:gap-5.mt-auto
        = render Heatpump::SensorKpiLink::Component.new( \
            data:,
            sensor_name: :outdoor_temp,
            timeframe:,
            css_class: kpi_link_classes,
            chart_url: heatpump_charts_path(sensor_name: 'outdoor_temp', timeframe:),
          )

        = render Heatpump::SensorKpiLink::Component.new( \
            data:,
            sensor_name: :heatpump_heating_power,
            timeframe:,
            css_class: kpi_link_classes,
            url: heatpump_home_path(sensor_name: 'heatpump_heating_power', timeframe:),
            chart_url: heatpump_charts_path(sensor_name: 'heatpump_heating_power', timeframe:),
          )

        = render Heatpump::SensorKpiLink::Component.new( \
            data:,
            sensor_name: :heatpump_tank_temp,
            timeframe:,
            css_class: kpi_link_classes,
            chart_url: heatpump_charts_path(sensor_name: 'heatpump_tank_temp', timeframe:),
          )
