= turbo_stream.update frame_id('timeframe') do
  = render Timeframe::Component.new(timeframe:)

- if timeframe.now? && Sensor::Config.exists?(:heatpump_status)
  = turbo_stream.update frame_id('status') do
    = render Status::Component.new time: data.time,
                                   status: data.heatpump_status

= turbo_stream.update frame_id('stats'), method: :morph do
  ruby:
    focus_ring_classes = 'focus:outline-none focus:ring-2 focus:ring-gray-700 dark:focus:ring-gray-400 focus:ring-offset-0'
    card_base_classes = "click-animation block min-w-0 rounded-xl #{focus_ring_classes}"
    kpi_link_classes = "#{card_base_classes} min-w-0 basis-auto grow [&>div]:w-full"
    costs_link_classes = "#{card_base_classes} bg-slate-200 px-3 py-2.5 text-slate-700 dark:bg-slate-800 dark:text-slate-400 md:px-4"

  .h-full.w-full.flex.flex-col.gap-3.lg:gap-4.xl:gap-5 id= "stats-#{timeframe.id}"
    - if !timeframe.now? && data.heatpump_costs
      = link_to url_for(controller: 'home', sensor_name: 'heatpump_costs', timeframe:),
                class: costs_link_classes,
                data: { \
                  controller: 'tooltip',
                  tooltip_placement_value: 'bottom',
                  tooltip_force_tap_to_close_value: false,
                  tooltip_touch_value: 'long',
                  turbo_prefetch: 'false',
                  'stats-with-chart--component-target': 'current',
                  'sensor-name': 'heatpump_costs',
                  value: data.heatpump_costs,
                  time: data.time.to_i,
                  action: 'stats-with-chart--component#loadChart',
                  stats_with_chart__component_sensor_name_param: 'heatpump_costs',
                  stats_with_chart__component_chart_url_param: heatpump_charts_path(sensor_name: 'heatpump_costs', timeframe:),
                } do
          - if data.heatpump_power_grid_ratio
            - power_pv_ratio = 100 - data.heatpump_power_grid_ratio
            .text-center.text-sm
              div
                = "#{power_pv_ratio.round}% aus Photovoltaik"
              .w-full.flex.gap-px.rounded.overflow-hidden.mt-1
                - if power_pv_ratio.positive?
                  .h-3.bg-sensor-pv[
                    style= "width: #{power_pv_ratio}%;"
                  ]
                - if data.heatpump_power_grid_ratio.positive?
                  .h-3.bg-sensor-grid[
                    style= "width: #{data.heatpump_power_grid_ratio}%;"
                  ]

          .mt-4.text-center
            = render SensorValue::Component.new(data.heatpump_costs, :total_costs, sign: :negative, class: 'text-3xl')

          #tooltip-content-heatpump_costs.hidden data-tooltip-target= 'html'
            = render SplittedCosts::Component.new( \
                costs: data.heatpump_costs,
                power_grid_ratio: data.heatpump_power_grid_ratio,
                grid_costs: data.heatpump_costs_grid,
                pv_costs: data.heatpump_costs_pv,
                show_power_breakdown: false,
              )

    - if data.heatpump_cop&.positive? || data.heatpump_tank_temp || data.outdoor_temp || data.heatpump_heating_power&.positive?
      .flex.w-full.flex-nowrap.gap-2.lg:gap-4.xl:gap-5
        - if data.outdoor_temp
          = link_to url_for(controller: 'home', sensor_name: 'outdoor_temp', timeframe:),
                    class: kpi_link_classes,
                    data: { \
                      turbo_prefetch: 'false',
                      'stats-with-chart--component-target': 'current',
                      'sensor-name': 'outdoor_temp',
                      value: data.outdoor_temp,
                      time: data.time.to_i,
                      action: 'stats-with-chart--component#loadChart',
                      stats_with_chart__component_sensor_name_param: 'outdoor_temp',
                      stats_with_chart__component_chart_url_param: heatpump_charts_path(sensor_name: 'outdoor_temp', timeframe:),
                    } do
            = render RectBadge::Component.new(title: Sensor::Registry[:outdoor_temp].display_name(:short)) do
              = render SensorValue::Component.new(data, :outdoor_temp)

        - if data.heatpump_heating_power&.positive?
          = link_to heatpump_home_path(sensor_name: 'heatpump_heating_power', timeframe:),
                    class: kpi_link_classes,
                    data: { \
                      turbo_prefetch: 'false',
                      'stats-with-chart--component-target': 'current',
                      'sensor-name': 'heatpump_heating_power',
                      value: data.heatpump_heating_power,
                      time: data.time.to_i,
                      action: 'stats-with-chart--component#loadChart',
                      stats_with_chart__component_sensor_name_param: 'heatpump_heating_power',
                      stats_with_chart__component_chart_url_param: heatpump_charts_path(sensor_name: 'heatpump_heating_power', timeframe:),
                    } do
            = render RectBadge::Component.new(title: Sensor::Registry[:heatpump_heating_power].display_name(:short)) do
              = render SensorValue::Component.new(data, :heatpump_heating_power, context: timeframe.now? ? :rate : :total)

        - if data.heatpump_cop&.positive?
          = link_to url_for(controller: 'home', sensor_name: 'heatpump_cop', timeframe:),
                    class: kpi_link_classes,
                    data: { \
                      turbo_prefetch: 'false',
                      'stats-with-chart--component-target': 'current',
                      'sensor-name': 'heatpump_cop',
                      value: data.heatpump_cop,
                      time: data.time.to_i,
                      action: 'stats-with-chart--component#loadChart',
                      stats_with_chart__component_sensor_name_param: 'heatpump_cop',
                      stats_with_chart__component_chart_url_param: heatpump_charts_path(sensor_name: 'heatpump_cop', timeframe:),
                    } do
            = render RectBadge::Component.new(title: Sensor::Registry[:heatpump_cop].display_name(:short)) do
              = render SensorValue::Component.new(data, :heatpump_cop, precision: 1)

        - if data.heatpump_tank_temp
          = link_to url_for(controller: 'home', sensor_name: 'heatpump_tank_temp', timeframe:),
                    class: kpi_link_classes,
                    data: { \
                      turbo_prefetch: 'false',
                      'stats-with-chart--component-target': 'current',
                      'sensor-name': 'heatpump_tank_temp',
                      value: data.heatpump_tank_temp,
                      time: data.time.to_i,
                      action: 'stats-with-chart--component#loadChart',
                      stats_with_chart__component_sensor_name_param: 'heatpump_tank_temp',
                      stats_with_chart__component_chart_url_param: heatpump_charts_path(sensor_name: 'heatpump_tank_temp', timeframe:),
                    } do
            = render RectBadge::Component.new(title: Sensor::Registry[:heatpump_tank_temp].display_name(:short)) do
              = render SensorValue::Component.new(data, :heatpump_tank_temp)

    .flex-1.flex
      = render SegmentContainer::Component.new tooltip_placement: 'bottom',
                                               data:,
                                               timeframe: do |container|
        - if data.heatpump_heating_power.nil? || data.heatpump_heating_power.zero?
          - container.with_segment :heatpump_heating_power,
                                   percent: 100,
                                   tooltip: false,
                                   color_class: 'bg-slate-600 dark:bg-slate-600/70' do
            p.text-xl
              = t('data.heatpump_no_heating')

        - elsif data.heatpump_power && data.heatpump_heating_power >= data.heatpump_power
          - container.with_segment :heatpump_power_env, inline: true
          - if timeframe.now?
            - container.with_segment :heatpump_power,
                                     title: t('splitter.total'),
                                     percent: data.heatpump_power_percent_heating,
                                     inline: true
          - else
            - container.with_segment :heatpump_power_pv,
                                     title: t('splitter.pv'),
                                     inline: true
            - container.with_segment :heatpump_power_grid,
                                     title: t('splitter.grid'),
                                     inline: true

        - elsif data.heatpump_heating_power.positive?
          - container.with_segment :heatpump_heating_power,
                                   percent: 100,
                                   tooltip: false,
                                   color_class: 'bg-slate-600 dark:bg-slate-600/70' do
            div
              p.text-xl.max-w-64
                = t('data.heatpump_cop_below_one')

              .mt-4.inline-block
                = render RectBadge::Component.new(title: t('splitter.total')) do
                  = render SensorValue::Component.new(data, :heatpump_power, context: :total)
