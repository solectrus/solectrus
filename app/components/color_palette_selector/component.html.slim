form.flex.items-center.justify-center.gap-4.w-40.p-2.rounded-xl.bg-indigo-200.lg:bg-gray-200.dark:bg-gray-950.focus:outline-hidden.opacity-80[
  data-controller= (ApplicationPolicy.themes? ? 'color-palette-selector--component' : 'tooltip')
  title= (t('.sponsors_only') unless ApplicationPolicy.themes?)
  data-tooltip-placement-value= 'top'
]
  label.cursor-pointer[
    class= ('pointer-events-none' unless ApplicationPolicy.themes?)
    title= t('.classic')
    data-controller= 'tooltip'
    data-tooltip-placement-value= 'top'
  ]
    input.sr-only.peer[
      type= 'radio'
      name= 'colorPalette'
      value= 'classic'
      data-action= 'color-palette-selector--component#classic toggle#hide'
      data-color-palette-selector--component-target= 'inputClassic'
    ]
    .grid.grid-cols-2.gap-1.rounded-lg.p-2.peer-checked:bg-white.dark:peer-checked:bg-gray-700/60.hover:bg-gray-100.dark:hover:bg-gray-800.transition-colors
      .w-5.h-3.rounded-sm style="background-color: var(--palette-classic-preview-battery)"
      .w-5.h-3.rounded-sm style="background-color: var(--palette-classic-preview-house)"
      .w-5.h-3.rounded-sm style="background-color: var(--palette-classic-preview-wallbox)"
      .w-5.h-3.rounded-sm style="background-color: var(--palette-classic-preview-heatpump)"

  label.cursor-pointer[
    class= ('pointer-events-none' unless ApplicationPolicy.themes?)
    title= t('.modern')
    data-controller= 'tooltip'
    data-tooltip-placement-value= 'top'
  ]
    input.sr-only.peer[
      type= 'radio'
      name= 'colorPalette'
      value= 'modern'
      data-action= 'color-palette-selector--component#modern toggle#hide'
      data-color-palette-selector--component-target= 'inputModern'
    ]
    .grid.grid-cols-2.gap-1.rounded-lg.p-2.peer-checked:bg-white.dark:peer-checked:bg-gray-700/60.hover:bg-gray-100.dark:hover:bg-gray-800.transition-colors
      .w-5.h-3.rounded-sm style="background-color: var(--palette-modern-preview-battery)"
      .w-5.h-3.rounded-sm style="background-color: var(--palette-modern-preview-house)"
      .w-5.h-3.rounded-sm style="background-color: var(--palette-modern-preview-wallbox)"
      .w-5.h-3.rounded-sm style="background-color: var(--palette-modern-preview-heatpump)"
