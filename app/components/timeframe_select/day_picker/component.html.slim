.day-picker.relative(
  data-controller= 'timeframe-select--day-picker--component'
  data-timeframe-select--day-picker--component-value-value= value
  data-timeframe-select--day-picker--component-ending-value-value= ending_value
  data-timeframe-select--day-picker--component-min-date-value= min_date
  data-timeframe-select--day-picker--component-max-date-value= max_date
  data-timeframe-select--day-picker--component-name-value= name
  data-timeframe-select--day-picker--component-range-value= range
)
  / Hidden input that holds the actual value (YYYY-MM-DD format or YYYY-MM-DD..YYYY-MM-DD for range)
  input[
    type= 'hidden'
    name= name
    data-timeframe-select--day-picker--component-target= 'hiddenInput'
  ]

  / Display button
  button.dropdown-icon.w-full.px-4.py-2.5.text-base.text-left.border.border-gray-300.dark:border-gray-600.rounded-lg.bg-white.dark:bg-gray-700.text-gray-900.dark:text-white.focus:outline-none.focus:ring-2.focus:ring-indigo-500.focus:border-indigo-500.appearance-none.cursor-pointer.transition-colors.hover:border-gray-400.dark:hover:border-gray-500 id=button_id type= 'button' data-action= 'timeframe-select--day-picker--component#toggle' data-timeframe-select--day-picker--component-target= 'displayButton'
    span data-timeframe-select--day-picker--component-target= 'displayText'
      = formatted_value

  / AirDatepicker will be rendered here by the Stimulus controller
  div data-timeframe-select--day-picker--component-target= 'pickerContainer'
