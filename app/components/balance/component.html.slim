div class= 'flex-1 flex h-full' id= "stats-#{timeframe.id}"
  = render SegmentContainer::Component.new tooltip_placement: 'right',
                                            data:,
                                            timeframe: do |balance|
    ruby:
      balance.with_title do
        link_to I18n.t('balance_sheet.left'),
                balance_home_path(sensor_name: 'power_balance', timeframe:),
                data: {
                  action: 'stats-with-chart--component#loadChart',
                  stats_with_chart__component_sensor_name_param: 'power_balance',
                  stats_with_chart__component_chart_url_param: balance_charts_path(sensor_name: 'power_balance', timeframe:),
                }
      end
      balance.with_segment :grid_import_power, peak: peak&.dig(:grid_import_power)

      balance.with_segment :battery_discharging_power, peak: peak&.dig(:battery_discharging_power)

      if Sensor::Config.multi_inverter? && ApplicationPolicy.multi_inverter? && data.valid_multi_inverter?
        if Setting.inverter_as_total
          balance.with_segment :inverter_power, peak: peak&.dig(:inverter_power)
        else
          Sensor::Config.custom_inverter_sensors.reverse_each do |inverter|
            balance.with_segment inverter.name,
                                 peak: peak&.dig(inverter.name),
                                 percent: data.public_send("#{inverter.name}_percent_of_total"),
                                 color_class: inverter.color_background
          end

          # Render hidden segment for total inverter power.
          # This is used for adding points to the chart
          balance.with_segment :inverter_power, hidden: true
        end
      else
        balance.with_segment :inverter_power, peak: peak&.dig(:inverter_power)
      end

  div class= 'flex flex-col px-2 sm:px-4 gap-2 tall:gap-4 pb-8'
    = center

  = render SegmentContainer::Component.new tooltip_placement: 'left',
                                            data:,
                                            timeframe: do |balance|
    ruby:
      balance.with_title do
        link_to I18n.t('balance_sheet.right'),
                balance_home_path(sensor_name: 'power_balance', timeframe:),
                data: {
                  action: 'stats-with-chart--component#loadChart',
                  stats_with_chart__component_sensor_name_param: 'power_balance',
                  stats_with_chart__component_chart_url_param: balance_charts_path(sensor_name: 'power_balance', timeframe:),
                }
      end

      balance.with_segment :house_power, peak: peak&.dig(:house_power)
      house_power_sensor = Sensor::Registry[:house_power]
      Sensor::Config.house_power_excluded_custom_sensors.each do |sensor|
        balance.with_segment sensor.name, color_class: "#{house_power_sensor.color_background} #{house_power_sensor.color_text}"
      end
      balance.with_segment :heatpump_power, peak: peak&.dig(:heatpump_power)
      balance.with_segment :wallbox_power, peak: peak&.dig(:wallbox_power)
      balance.with_segment :battery_charging_power, peak: peak&.dig(:battery_charging_power)
      balance.with_segment :grid_export_power, peak: peak&.dig(:grid_export_power)
